/**
 * ========================================
 * REGISTRO DE POST TYPE: ARTISTA
 * ========================================
 */
function cc_registrar_post_type_artista() {
    $labels = array(
        'name'                  => 'Artistas',
        'singular_name'         => 'Artista',
        'menu_name'             => 'Artistas',
        'add_new'               => 'Agregar Nuevo',
        'add_new_item'          => 'Agregar Nuevo Artista',
        'edit_item'             => 'Editar Artista',
        'new_item'              => 'Nuevo Artista',
        'view_item'             => 'Ver Artista',
        'view_items'            => 'Ver Artistas',
        'search_items'          => 'Buscar Artistas',
        'not_found'             => 'No se encontraron artistas',
        'not_found_in_trash'    => 'No se encontraron artistas en la papelera',
        'all_items'             => 'Todos los Artistas',
        'archives'              => 'Archivo de Artistas',
        'attributes'            => 'Atributos de Artista',
        'insert_into_item'      => 'Insertar en artista',
        'uploaded_to_this_item' => 'Subido a este artista',
    );

    $args = array(
        'labels'              => $labels,
        'public'              => true,
        'publicly_queryable'  => true,
        'show_ui'             => true,
        'show_in_menu'        => true,
        'menu_position'       => 7,
        'menu_icon'           => 'dashicons-art',
        'capability_type'     => 'post',
        'hierarchical'        => false,
        'supports'            => array('title', 'editor', 'thumbnail', 'excerpt', 'revisions'),
        'has_archive'         => true,
        'rewrite'             => array('slug' => 'artistas'),
        'show_in_rest'        => true,
        'rest_base'           => 'artistas',
    );

    register_post_type('artista', $args);
}
add_action('init', 'cc_registrar_post_type_artista');

/**
 * Flush rewrite rules en activación
 */
function cc_artistas_flush_rewrites() {
    cc_registrar_post_type_artista();
    flush_rewrite_rules();
}
register_activation_hook(__FILE__, 'cc_artistas_flush_rewrites');

/**
 * Asegurar que ACF cargue para el post type artista
 */
function cc_artista_acf_init() {
    // Verificar que ACF esté activo
    if (!function_exists('acf_add_local_field_group')) {
        add_action('admin_notices', function() {
            if (get_post_type() === 'artista') {
                echo '<div class="notice notice-warning"><p><strong>Advertencia:</strong> Advanced Custom Fields no está activo. Los campos personalizados de Artista no funcionarán correctamente.</p></div>';
            }
        });
    }
}
add_action('acf/init', 'cc_artista_acf_init');

/**
 * Registrar soporte para campos personalizados en artista
 */
function cc_artista_custom_field_support() {
    // Asegurar que el post type soporte campos personalizados
    add_post_type_support('artista', 'custom-fields');
}
add_action('init', 'cc_artista_custom_field_support', 20);

/**
 * Debug: Verificar carga de campos ACF (solo para admin)
 */
function cc_artista_debug_acf() {
    if (!is_admin() || !current_user_can('manage_options')) {
        return;
    }
    
    if (isset($_GET['post']) || (isset($_GET['post_type']) && $_GET['post_type'] === 'artista')) {
        $field_groups = function_exists('acf_get_field_groups') ? acf_get_field_groups(['post_type' => 'artista']) : [];
        
        if (empty($field_groups)) {
            add_action('admin_notices', function() {
                echo '<div class="notice notice-error"><p><strong>ACF Debug:</strong> No se encontraron grupos de campos para el post type "artista". Verifica que acf_fields-artista.php se esté cargando correctamente.</p></div>';
            });
        }
    }
}
add_action('admin_init', 'cc_artista_debug_acf');

/**
 * ========================================
 * FUNCIONES HELPER PARA ARTISTAS
 * ========================================
 */

/**
 * Obtener todas las disciplinas del artista
 */
function cc_obtener_disciplinas_artista($post_id = null) {
    if (!$post_id) {
        $post_id = get_the_ID();
    }
    
    $disciplina = get_field('disciplina_artistica', $post_id);
    $todas_disciplinas = array();
    
    // Campos de disciplinas a revisar
    $campos_disciplina = array(
        'artes_visuales',
        'artes_literarias',
        'artes_escenicas',
        'artes_musicales',
        'artes_aplicadas__decorativas',
        'otros'
    );
    
    // Recorrer cada campo de disciplina
    foreach ($campos_disciplina as $campo) {
        if (!empty($disciplina[$campo])) {
            if (is_array($disciplina[$campo])) {
                // Si es un array (múltiples selecciones)
                foreach ($disciplina[$campo] as $valor) {
                    $todas_disciplinas[] = $valor;
                }
            } else {
                // Si es un solo valor
                $todas_disciplinas[] = $disciplina[$campo];
            }
        }
    }
    
    return $todas_disciplinas;
}

/**
 * Obtener imágenes del slider del artista
 */
function cc_get_slider_artista($post_id = null) {
    if (!$post_id) {
        $post_id = get_the_ID();
    }
    
    $slider = get_field('slider_de_imagenes', $post_id);
    $imagenes = array();
    
    if ($slider && is_array($slider)) {
        for ($i = 1; $i <= 5; $i++) {
            if (!empty($slider['imagen_' . $i])) {
                $imagenes[] = $slider['imagen_' . $i];
            }
        }
    }
    
    return $imagenes;
}

/**
 * Obtener redes sociales del artista
 */
function cc_get_redes_sociales_artista($post_id = null) {
    if (!$post_id) {
        $post_id = get_the_ID();
    }
    
    $redes = get_field('redes_sociales', $post_id);
    
    if (!$redes || !is_array($redes)) {
        return array();
    }
    
    $redes_disponibles = array();
    
    $redes_config = array(
        'facebook_url' => array('nombre' => 'Facebook', 'icono' => 'fa-facebook-f', 'clase' => 'facebook'),
        'instagram_url' => array('nombre' => 'Instagram', 'icono' => 'fa-instagram', 'clase' => 'instagram'),
        'x_url' => array('nombre' => 'X (Twitter)', 'icono' => 'fa-x-twitter', 'clase' => 'twitter'),
        'spotify_url' => array('nombre' => 'Spotify', 'icono' => 'fa-spotify', 'clase' => 'spotify'),
        'pinterest_url' => array('nombre' => 'Pinterest', 'icono' => 'fa-pinterest-p', 'clase' => 'pinterest'),
        'tiktok_url' => array('nombre' => 'TikTok', 'icono' => 'fa-tiktok', 'clase' => 'tiktok'),
        'youtube_url' => array('nombre' => 'YouTube', 'icono' => 'fa-youtube', 'clase' => 'youtube'),
        'linkedin_url' => array('nombre' => 'LinkedIn', 'icono' => 'fa-linkedin-in', 'clase' => 'linkedin'),
        'otro_url' => array('nombre' => 'Sitio Web', 'icono' => 'fa-link', 'clase' => 'link'),
    );
    
    foreach ($redes_config as $key => $config) {
        if (!empty($redes[$key])) {
            $redes_disponibles[$key] = array_merge($config, array('url' => $redes[$key]));
        }
    }
    
    return $redes_disponibles;
}

/**
 * Formatear número de teléfono para WhatsApp (Ecuador)
 */
function cc_formatear_whatsapp_artista($numero) {
    if (empty($numero)) {
        return '';
    }
    
    // Limpiar el número (solo dígitos)
    $numero = preg_replace('/[^0-9]/', '', $numero);
    
    // Si no empieza con 593, añadir código de país para Ecuador
    if (substr($numero, 0, 3) !== '593') {
        // Si empieza con 0, reemplazarlo con 593
        if (substr($numero, 0, 1) === '0') {
            $numero = '593' . substr($numero, 1);
        } else {
            $numero = '593' . $numero;
        }
    }
    
    return $numero;
}

/**
 * ========================================
 * QUERIES Y LISTADOS
 * ========================================
 */

/**
 * Obtener artistas por disciplina
 */
function cc_get_artistas_por_disciplina($disciplina, $limit = 10) {
    $args = array(
        'post_type' => 'artista',
        'posts_per_page' => $limit,
        'meta_query' => array(
            'relation' => 'OR',
            array(
                'key' => 'disciplina_artistica_artes_visuales',
                'value' => $disciplina,
                'compare' => 'LIKE'
            ),
            array(
                'key' => 'disciplina_artistica_artes_literarias',
                'value' => $disciplina,
                'compare' => 'LIKE'
            ),
            array(
                'key' => 'disciplina_artistica_artes_escenicas',
                'value' => $disciplina,
                'compare' => 'LIKE'
            ),
            array(
                'key' => 'disciplina_artistica_artes_musicales',
                'value' => $disciplina,
                'compare' => 'LIKE'
            ),
            array(
                'key' => 'disciplina_artistica_artes_aplicadas__decorativas',
                'value' => $disciplina,
                'compare' => 'LIKE'
            ),
        ),
        'orderby' => 'title',
        'order' => 'ASC'
    );
    
    return new WP_Query($args);
}

/**
 * Obtener todos los artistas
 */
function cc_get_todos_artistas($limit = -1) {
    $args = array(
        'post_type' => 'artista',
        'posts_per_page' => $limit,
        'orderby' => 'title',
        'order' => 'ASC'
    );
    
    return new WP_Query($args);
}

/**
 * ========================================
 * SHORTCODES
 * ========================================
 */

/**
 * Shortcode para mostrar artistas
 * Uso: [mostrar_artistas limit="9" disciplina=""]
 */
function cc_shortcode_mostrar_artistas($atts) {
    $atts = shortcode_atts(array(
        'limit' => 9,
        'disciplina' => '',
    ), $atts);
    
    if (!empty($atts['disciplina'])) {
        $query = cc_get_artistas_por_disciplina($atts['disciplina'], $atts['limit']);
    } else {
        $query = cc_get_todos_artistas($atts['limit']);
    }
    
    ob_start();
    
    if ($query->have_posts()) {
        echo '<div class="artistas-archive-container">';
        echo '<div class="artistas-grid">';
        
        while ($query->have_posts()) {
            $query->the_post();
            
            $disciplinas = cc_obtener_disciplinas_artista();
            $disciplina_principal = !empty($disciplinas) ? $disciplinas[0] : '';
            $slider = get_field('slider_de_imagenes');
            $imagen_destacada = !empty($slider['imagen_1']) ? $slider['imagen_1'] : null;
            
            echo '<article class="artista-card">';
            echo '<div class="artista-card-image">';
            
            if ($imagen_destacada) {
                echo '<img src="' . esc_url($imagen_destacada['url']) . '" alt="' . esc_attr(get_the_title()) . '">';
            } elseif (has_post_thumbnail()) {
                the_post_thumbnail('medium_large');
            } else {
                echo '<img src="' . get_template_directory_uri() . '/assets/img/artista-placeholder.jpg" alt="' . esc_attr(get_the_title()) . '">';
            }
            
            echo '</div>';
            echo '<div class="artista-card-content">';
            echo '<h2 class="artista-card-title"><a href="' . get_permalink() . '">' . get_the_title() . '</a></h2>';
            
            if ($disciplina_principal) {
                echo '<div class="artista-card-disciplina">';
                echo esc_html($disciplina_principal);
                if (count($disciplinas) > 1) {
                    echo '<span class="disciplina-count">+' . (count($disciplinas) - 1) . '</span>';
                }
                echo '</div>';
            }
            
            echo '<div class="artista-card-excerpt">' . get_the_excerpt() . '</div>';
            echo '<a href="' . get_permalink() . '" class="artista-card-btn">Ver perfil</a>';
            echo '</div>';
            echo '</article>';
        }
        
        echo '</div>';
        echo '</div>';
        
        wp_reset_postdata();
    } else {
        echo '<div class="artistas-empty"><p>No se encontraron artistas.</p></div>';
    }
    
    return ob_get_clean();
}
add_shortcode('mostrar_artistas', 'cc_shortcode_mostrar_artistas');

/**
 * ========================================
 * DASHBOARD WIDGET
 * ========================================
 */

/**
 * Dashboard widget: Resumen de artistas
 */
function cc_dashboard_widget_artistas() {
    $total_artistas = wp_count_posts('artista')->publish;
    $recientes = cc_get_todos_artistas(5);
    
    echo '<div class="artistas-dashboard">';
    echo '<div class="artista-stats">';
    echo '<div class="stat-box">';
    echo '<span class="stat-number">' . $total_artistas . '</span>';
    echo '<span class="stat-label">Artistas Registrados</span>';
    echo '</div>';
    echo '</div>';
    
    if ($recientes->have_posts()) {
        echo '<h4 style="margin-top: 20px; margin-bottom: 10px;">Artistas Recientes</h4>';
        echo '<ul style="list-style: none; padding: 0; margin: 0;">';
        
        while ($recientes->have_posts()) {
            $recientes->the_post();
            $disciplinas = cc_obtener_disciplinas_artista();
            $disciplina_principal = !empty($disciplinas) ? $disciplinas[0] : '';
            
            echo '<li style="padding: 10px; border-bottom: 1px solid #eee;">';
            echo '<strong>' . get_the_title() . '</strong>';
            if ($disciplina_principal) {
                echo '<br><small style="color: #787c82;">' . esc_html($disciplina_principal) . '</small>';
            }
            echo '<br><a href="' . get_edit_post_link() . '">Editar</a> | ';
            echo '<a href="' . get_permalink() . '" target="_blank">Ver</a>';
            echo '</li>';
        }
        
        echo '</ul>';
        wp_reset_postdata();
    }
    
    echo '<p style="margin-top: 15px;">';
    echo '<a href="' . admin_url('edit.php?post_type=artista') . '" class="button button-primary">Ver Todos los Artistas</a> ';
    echo '<a href="' . admin_url('post-new.php?post_type=artista') . '" class="button">Agregar Artista</a>';
    echo '</p>';
    
    echo '</div>';
}

function cc_agregar_dashboard_widget_artistas() {
    wp_add_dashboard_widget(
        'cc_artistas_widget',
        '🎨 Artistas - Casa de la Cultura',
        'cc_dashboard_widget_artistas'
    );
}
add_action('wp_dashboard_setup', 'cc_agregar_dashboard_widget_artistas');

/**
 * ========================================
 * ENQUEUE STYLES & SCRIPTS
 * ========================================
 */

/**
 * Cargar estilos y scripts para artistas
 */
function cc_enqueue_artista_assets() {
    // Página individual de artista
    if (is_singular('artista')) {
        wp_enqueue_style(
            'artista-styles',
            get_template_directory_uri() . '/artista/artista-styles.css',
            array(),
            '1.0.0'
        );
    }
    
    // Archivo de artistas
    if (is_post_type_archive('artista') || (is_tax() && get_post_type() == 'artista')) {
        wp_enqueue_style(
            'archive-artista-styles',
            get_template_directory_uri() . '/artista/archive-artista-styles.css',
            array(),
            '1.0.0'
        );
    }
    
    // Font Awesome para iconos de redes sociales
    if (is_singular('artista') || is_post_type_archive('artista')) {
        wp_enqueue_style(
            'font-awesome',
            'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css',
            array(),
            '6.4.2'
        );
    }
}
add_action('wp_enqueue_scripts', 'cc_enqueue_artista_assets');

/**
 * ========================================
 * COLUMNAS PERSONALIZADAS EN ADMIN
 * ========================================
 */

/**
 * Agregar columnas personalizadas
 */
function cc_artistas_columnas_admin($columns) {
    $new_columns = array();
    
    foreach ($columns as $key => $value) {
        $new_columns[$key] = $value;
        
        if ($key === 'title') {
            $new_columns['artista_disciplina'] = 'Disciplina';
            $new_columns['artista_contacto'] = 'Contacto';
        }
    }
    
    return $new_columns;
}
add_filter('manage_artista_posts_columns', 'cc_artistas_columnas_admin');

/**
 * Rellenar columnas personalizadas
 */
function cc_artistas_columnas_contenido($column, $post_id) {
    switch ($column) {
        case 'artista_disciplina':
            $disciplinas = cc_obtener_disciplinas_artista($post_id);
            if (!empty($disciplinas)) {
                echo '<strong>' . esc_html($disciplinas[0]) . '</strong>';
                if (count($disciplinas) > 1) {
                    echo '<br><small>+' . (count($disciplinas) - 1) . ' más</small>';
                }
            } else {
                echo '—';
            }
            break;
            
        case 'artista_contacto':
            $numero = get_field('numero_de_contacto', $post_id);
            $correo = get_field('correo_electronico', $post_id);
            
            if ($numero) {
                echo '<span class="dashicons dashicons-phone"></span> ' . esc_html($numero) . '<br>';
            }
            if ($correo) {
                echo '<span class="dashicons dashicons-email"></span> ' . esc_html($correo);
            }
            if (!$numero && !$correo) {
                echo '—';
            }
            break;
    }
}
add_action('manage_artista_posts_custom_column', 'cc_artistas_columnas_contenido', 10, 2);

/**
 * Hacer columnas ordenables
 */
function cc_artistas_columnas_ordenables($columns) {
    $columns['artista_disciplina'] = 'disciplina_artistica';
    return $columns;
}
add_filter('manage_edit-artista_sortable_columns', 'cc_artistas_columnas_ordenables');
?>